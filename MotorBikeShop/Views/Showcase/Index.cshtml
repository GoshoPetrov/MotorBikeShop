@model ShowcaseViewModel

@if (!string.IsNullOrWhiteSpace(ViewBag.Message))
{
    <div id="messageAlert" class="alert alert-warning d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @ViewBag.Message
    </div>

}

<div style="display:flex; justify-content:space-between; align-items:center;">
    <h2>Bike Showcase</h2>

    <a asp-controller="Basket" asp-action="Index" class="btn btn-warning">
        View Basket
    </a>
</div>

<form asp-action="Index" method="get">
    <input type="hidden" name="sortBy" value="@Model.SortBy" />
    <input type="hidden" name="ascending" value="@Model.Ascending.ToString().ToLower()" />
    <input type="hidden" name="pageSize" value="@Model.PageSize" />
    <input id="searchString" type="text" name="searchString" value="@Context.Request.Query["searchString"]"
           placeholder="Search by bike name..." />
    <button type="submit" class="btn btn-primary">Search</button>
    <a asp-action="Index" class="btn btn-secondary">Clear</a>
    <div id="searchResults" class="list-group mt-1"></div>
</form>

<!-- Sort Controls -->
<div class="row mb-3 mt-3">
    <div class="col">
        <strong>Sort by:</strong>
        <a asp-action="Index"
           asp-route-sortBy="Name"
           asp-route-ascending="@(Model.SortBy == "Name" ? !Model.Ascending : true)"
           asp-route-searchString="@Context.Request.Query["searchString"]"
           asp-route-pageNumber="1"
           asp-route-pageSize="@Model.PageSize"
           class="text-decoration-none ms-1">
            Name
            @if (Model.SortBy == "Name")
            {
                <i class="bi bi-caret-@(Model.Ascending ? "up" : "down")-fill"></i>
            }
        </a>
        <span class="mx-1">|</span>
        <a asp-action="Index"
           asp-route-sortBy="Brand"
           asp-route-ascending="@(Model.SortBy == "Brand" ? !Model.Ascending : true)"
           asp-route-searchString="@Context.Request.Query["searchString"]"
           asp-route-pageNumber="1"
           asp-route-pageSize="@Model.PageSize"
           class="text-decoration-none">
            Brand
            @if (Model.SortBy == "Brand")
            {
                <i class="bi bi-caret-@(Model.Ascending ? "up" : "down")-fill"></i>
            }
        </a>
        <span class="mx-1">|</span>
        <a asp-action="Index"
           asp-route-sortBy="Price"
           asp-route-ascending="@(Model.SortBy == "Price" ? !Model.Ascending : true)"
           asp-route-searchString="@Context.Request.Query["searchString"]"
           asp-route-pageNumber="1"
           asp-route-pageSize="@Model.PageSize"
           class="text-decoration-none">
            Price
            @if (Model.SortBy == "Price")
            {
                <i class="bi bi-caret-@(Model.Ascending ? "up" : "down")-fill"></i>
            }
        </a>
        <span class="mx-1">|</span>
        <a asp-action="Index"
           asp-route-sortBy="Year"
           asp-route-ascending="@(Model.SortBy == "Year" ? !Model.Ascending : true)"
           asp-route-searchString="@Context.Request.Query["searchString"]"
           asp-route-pageNumber="1"
           asp-route-pageSize="@Model.PageSize"
           class="text-decoration-none">
            Year
            @if (Model.SortBy == "Year")
            {
                <i class="bi bi-caret-@(Model.Ascending ? "up" : "down")-fill"></i>
            }
        </a>
    </div>
</div>

<!-- Results Summary -->
<div class="row mb-2">
    <div class="col">
        <small class="text-muted">
            Showing @Model.FirstItemIndex&ndash;@Model.LastItemIndex of @Model.TotalItems bike(s)
        </small>
    </div>
</div>

<div class="row">
    @foreach (var bike in Model.Bikes)
    {
        <div class="col-md-4">
            <div class="card" style="margin-bottom:20px;">

                <!-- IMAGE -->
                <img src="@bike.ImageUrl"
                     class="card-img-top"
                     style="height:200px; object-fit:cover;" />

                <div class="card-body">
                    <h5 class="card-title">@bike.Name</h5>
                    <p><strong>Brand:</strong> @bike.Brand</p>
                    <p><strong>Price:</strong> @bike.Price</p>

                    <a asp-action="Details"
                       asp-route-id="@bike.Id"
                       class="btn btn-primary">
                        View Details
                    </a>

                    <form asp-controller="Basket" asp-action="Add" method="post">
                        <input type="hidden" name="bikeModelId" value="@bike.Id" />
                        @if (bike.InventoryQuantity != null && bike.InventoryQuantity > 0)
                        {
                            <button class="btn btn-success">Add to Basket</button>
                        }
                        else
                        {
                            <button class="btn btn-secondary" disabled>Out of Stock</button>
                        }
                    </form>
                    <p><strong>In Stock:</strong> @bike.InventoryQuantity</p>
                </div>
            </div>
        </div>
    }
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav aria-label="Bike showcase navigation">
        <ul class="pagination justify-content-center">
            <!-- Previous -->
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" asp-action="Index"
                   asp-route-pageNumber="@(Model.PageNumber - 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-sortBy="@Model.SortBy"
                   asp-route-ascending="@Model.Ascending"
                   asp-route-searchString="@Context.Request.Query["searchString"]">
                    &laquo; Previous
                </a>
            </li>

            <!-- Page numbers -->
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@i"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-ascending="@Model.Ascending"
                       asp-route-searchString="@Context.Request.Query["searchString"]">
                        @i
                    </a>
                </li>
            }

            <!-- Next -->
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" asp-action="Index"
                   asp-route-pageNumber="@(Model.PageNumber + 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-sortBy="@Model.SortBy"
                   asp-route-ascending="@Model.Ascending"
                   asp-route-searchString="@Context.Request.Query["searchString"]">
                    Next &raquo;
                </a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        setTimeout(function () {
            const alert = document.getElementById('messageAlert');
            if (alert) {
                alert.classList.add('fade');
                setTimeout(() => alert.remove(), 150);
            }
        }, 3000);

        let timer;

        $("#searchString").on("input", function () {
            clearTimeout(timer);

            timer = setTimeout(async () => {
                const search = $(this).val();

                // Ajax call or form submit
                console.log("Searching for:", search);

                const response = await fetch(`/api/search?term=${encodeURIComponent(search)}`);

                const data = await response.json();

                console.log(data);
                renderResults(data);

            }, 500);
        });

        function renderResults(items) {
            clearResults();

            const resultsBox = document.getElementById("searchResults");
            const input = document.getElementById("searchString");

            if (!items || items.length === 0) {
                resultsBox.innerHTML = `<div class="list-group-item text-muted">No results found</div>`;
                return;
            }

            items.forEach(item => {
                const div = document.createElement("div");
                div.className = "list-group-item list-group-item-action";
                div.textContent = item;

                // optional click behavior
                div.addEventListener("click", () => {
                    input.value = item;
                    clearResults();
                });

                resultsBox.appendChild(div);
            });
        }

        function clearResults() {
            const resultsBox = document.getElementById("searchResults");
            resultsBox.innerHTML = "";
        }
    </script>
}