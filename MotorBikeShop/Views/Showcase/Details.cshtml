@model BikeViewModel

<h2>@Model.Name</h2>

<!-- IMAGE -->
<img src="@Model.ImageUrl"
     style="width:100%; max-width:500px; height:auto; object-fit:cover; margin-bottom:20px;" />

<div>
    <p><strong>Brand:</strong> @Model.Brand</p>
    <p><strong>Year:</strong> @Model.Year</p>
    <p><strong>Price:</strong> @Model.Price</p>
    <p><strong>Description:</strong> @Model.Description</p>
</div>

<a asp-action="Index" class="btn btn-secondary">Back to Showcase</a>

<form asp-controller="Basket" asp-action="Add" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="bikeModelId" value="@Model.Id" />
    @if (Model.InventoryQuantity > 0)
    {
        <form asp-controller="Basket" asp-action="Add" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="bikeModelId" value="@Model.Id" />
            <button class="btn btn-success">Add to Basket</button>
        </form>
    }
    else
    {
        <button class="btn btn-secondary" disabled>Out of Stock</button>
    }
</form>