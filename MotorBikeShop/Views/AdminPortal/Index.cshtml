@model IEnumerable<BikeViewModel>

<h2>Admin - Bike Management</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Brand</th>
            <th>Year</th>
            <th>Price</th>
            <th>Stock</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var bike in Model)
        {
            <tr>
                <td>@bike.Id</td>
                <td>@bike.Name</td>
                <td>@bike.Brand</td>
                <td>@bike.Year</td>
                <td>@bike.Price</td>
                <td>
                    @(bike.InventoryQuantity != null ? bike.InventoryQuantity : 0)
                </td>
                <td>
                    <a asp-action="Export" class="btn btn-success">Export Bikes</a>
                    <a asp-action="Import" class="btn btn-primary">Import Bikes</a>
                </td>
            </tr>
        }
    </tbody>
</table>